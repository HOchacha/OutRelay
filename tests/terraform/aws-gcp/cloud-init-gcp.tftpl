#!/bin/bash
# Startup script for the GCP-side provider VM. Mirrors the AWS
# agent-host cloud-init: pulls binaries + PKI from GCS, drops them
# into /opt/outrelay, runs a tiny python3 echo HTTP server, and
# starts outrelay-agent under systemd. Debian 12 ships gcloud /
# gsutil (via google-cloud-cli) and python3 by default.
#
# Variables interpolated by Terraform:
#   gcs_bucket, relay_endpoint, tenant, agent_uuid, cert_prefix,
#   role, service_name

set -eux

GCS_BUCKET="${gcs_bucket}"
RELAY="${relay_endpoint}"
TENANT="${tenant}"
UUID="${agent_uuid}"
CERT_PREFIX="${cert_prefix}"
ROLE="${role}"
SVC="${service_name}"

OUT=/opt/outrelay
mkdir -p $OUT/bin $OUT/pki

# gsutil auto-authenticates via the metadata server using the VM's
# attached service account.
gsutil cp gs://$GCS_BUCKET/bin/outrelay-agent  $OUT/bin/outrelay-agent
gsutil cp gs://$GCS_BUCKET/pki/ca.crt          $OUT/pki/ca.crt
gsutil cp gs://$GCS_BUCKET/pki/$CERT_PREFIX.crt $OUT/pki/agent.crt
gsutil cp gs://$GCS_BUCKET/pki/$CERT_PREFIX.key $OUT/pki/agent.key
chmod +x $OUT/bin/outrelay-agent
chmod 600 $OUT/pki/*.key

useradd --system --no-create-home --shell /usr/sbin/nologin outrelay || true
chown -R outrelay:outrelay $OUT

# Echo HTTP server matching the AWS variant — fast on /, slow on /slow.
mkdir -p /var/lib/outrelay-echo
cat >/var/lib/outrelay-echo/server.py <<PYEOF
import http.server, sys, time

ROLE = sys.argv[1]
BODY_FAST = ("ok from " + ROLE).encode()
BODY_SLOW = ("ok-slow from " + ROLE).encode()

class H(http.server.BaseHTTPRequestHandler):
    def log_message(self, *a, **k):
        return
    def do_GET(self):
        if self.path.startswith("/slow"):
            time.sleep(8)
            body = BODY_SLOW
        else:
            body = BODY_FAST
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

http.server.HTTPServer(("127.0.0.1", 8080), H).serve_forever()
PYEOF

cat >/etc/systemd/system/outrelay-echo.service <<EOF
[Unit]
Description=OutRelay smoke echo HTTP server
After=network-online.target

[Service]
Type=simple
User=outrelay
ExecStart=/usr/bin/python3 /var/lib/outrelay-echo/server.py $ROLE
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now outrelay-echo.service

# outrelay-agent unit. Same flag set as AWS agent-host: explicit-mode
# interception, --p2p-listen for §3.19 direct dials, srflx auto-
# discovery handles the external IP advertisement (ephemeral public
# IP appears on the eth0 interface here, so HostCandidates already
# emits it as a host candidate even without --p2p-advertise).
ARGS=(
  "--relay=$RELAY"
  "--cert=$OUT/pki/agent.crt"
  "--key=$OUT/pki/agent.key"
  "--ca=$OUT/pki/ca.crt"
  "--uri=outrelay://$TENANT/agent/$UUID"
  "--intercept=explicit"
  "--server-name=localhost"
  "--p2p-listen=0.0.0.0:7445"
  "--expose-service=$SVC"
  "--expose-target=127.0.0.1:8080"
  "--log-format=json"
)
EXEC="$OUT/bin/outrelay-agent $${ARGS[*]}"

cat >/etc/systemd/system/outrelay-$ROLE.service <<EOF
[Unit]
Description=OutRelay agent ($ROLE)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=outrelay
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart=$EXEC
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl enable --now outrelay-$ROLE.service
